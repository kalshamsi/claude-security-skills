# Partially improved Dockerfile with multi-stage build — still contains issues.
# Used as a test fixture for docker-scout-scanner to validate graduated findings.

# ── Build stage ────────────────────────────────────────────────────────────────
# Issue: latest tag on builder stage — CWE-1104, A06
FROM node:latest AS builder

WORKDIR /build

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# ── Runtime stage ──────────────────────────────────────────────────────────────
# Issue: latest tag on runtime stage — CWE-1104, A06
FROM node:latest

WORKDIR /app

COPY --from=builder /build/dist ./dist
COPY --from=builder /build/node_modules ./node_modules
COPY --from=builder /build/package.json ./

# Issue: USER is set, but only after COPY instructions.
# Files copied above are owned by root before the USER switch — CWE-732, A01
# A correct pattern would be: COPY --chown=node:node ...
USER node

EXPOSE 3000

# Issue: No HEALTHCHECK directive — CWE-693, A07
# (HEALTHCHECK intentionally omitted)

# Issue: Shell form ENTRYPOINT — CWE-693, A07
ENTRYPOINT node dist/server.js
